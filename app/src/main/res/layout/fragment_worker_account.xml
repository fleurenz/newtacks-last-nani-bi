<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== HERO SECTION ===== -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#004A99"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_person_placeholder"
                android:background="@drawable/bg_circle_translucent"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="Worker Icon" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvWorkerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Worker Name"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVerificationBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="NC3"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="14sp"
                    android:textColor="#FFD54F" />

                <TextView
                    android:id="@+id/tvWorkerRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 (0 reviews)"
                    android:textColor="#D6E6F5"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ===== CONTENT AREA ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORKER STATISTICS"
                android:textColor="#004A99"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <!-- STATS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="18dp">

                <!-- Accepted Jobs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_inbox"
                        android:contentDescription="@null"
                        app:tint="#004A99" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Accepted Jobs"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/tvAcceptedJobs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F1F5F9"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp" />

                <!-- Completed Jobs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="@null"
                        app:tint="#16A34A" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Completed Jobs"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/tvCompletedJobs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- VERIFICATION SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFICATION STATUS"
                android:textColor="#004A99"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvVerificationLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Unverified"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_margin="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUploadNC1"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NC1"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="#004A99" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUploadNC2"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NC2"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="#004A99" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUploadNC3"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NC3"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="#004A99" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload TESDA certificates to level up your status."
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- REVIEWS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REVIEWS"
                android:textColor="#004A99"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="12dp" />

            <!-- Star Filters -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <TextView
                        android:id="@+id/filterAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_badge_blue"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/filter5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 ⭐"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_badge_white"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/filter4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 ⭐"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_badge_white"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/filter3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 ⭐"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_badge_white"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/filter2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 ⭐"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_badge_white"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/filter1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 ⭐"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_badge_white"
                        android:textColor="#64748B"
                        android:textSize="13sp" />

                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/reviewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvSeeAllReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="See all"
                android:textColor="#004A99"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginTop="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:text="Logout"
                android:textColor="#E53935"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="12dp"
                app:strokeColor="#E53935"
                app:strokeWidth="1.5dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>