<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#004A99">

    <!-- Logo circle -->
    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginBottom="24dp">

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/circle_white" />

        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:src="@drawable/tacks_logo"
            android:scaleType="fitCenter"
            android:contentDescription="App Logo" />

    </FrameLayout>

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TACKS"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="6dp" />

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blue Collar Services"
        android:textColor="#AACDE8"
        android:textSize="14sp"
        android:letterSpacing="0.05"
        android:layout_marginBottom="48dp" />

    <!-- ✅ Realistic loading -->
    <ProgressBar
        android:id="@+id/splashProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:indeterminate="false"
        android:progressTint="#F59E0B"
        android:progressBackgroundTint="#1AFFFFFF"
        android:background="@drawable/bg_progress_track" />

    <!-- Status text -->
    <TextView
        android:id="@+id/tvSplashStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Initializing..."
        android:textColor="#AACDE8"
        android:textSize="12sp"
        android:layout_marginTop="12dp"
        android:letterSpacing="0.03" />

</LinearLayout>