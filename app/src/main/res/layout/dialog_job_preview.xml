<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp"
    app:cardElevation="0dp">

    <!-- ===== SINGLE CHILD: LinearLayout wraps everything ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="4dp"
                android:layout_height="22dp"
                android:background="#004A99"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="JOB PREVIEW"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
        </LinearLayout>

        <!-- Job Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1E293B"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="16dp" />

        <!-- Details -->
        <TextView
            android:id="@+id/tvDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#475569"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="12dp" />

        <!-- Duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_clock"
                app:tint="#64748B"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Images Section -->
        <TextView
            android:id="@+id/tvImagesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOB IMAGES"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:id="@+id/scrollImages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:id="@+id/layoutImages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Dynamic images -->
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvNoImages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No images provided"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            android:fontStyle="italic"
            android:visibility="gone"
            android:layout_marginBottom="20dp" />

        <!-- Dashed divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/bg_divider_dashed"
            android:layout_marginBottom="20dp" />

        <!-- Accept button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Accept Job"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            app:backgroundTint="#004A99"
            app:cornerRadius="12dp"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart" />

        <!-- Close button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Close"
            android:textColor="#64748B"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#F1F5F9"
            app:cornerRadius="12dp"
            app:strokeColor="#CBD5E1"
            app:strokeWidth="1dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>