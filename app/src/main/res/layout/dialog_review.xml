<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_role_card"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="20dp">

    <!-- Icon -->
    <ImageView
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_nav_account"
        android:background="@drawable/bg_circle"
        android:backgroundTint="#EBF2FF"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="Review icon"
        app:tint="#004A99" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Rate Worker"
        android:textColor="#004A99"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="How was your experience?"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="20dp" />

    <!-- Rating Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YOUR RATING"
        android:textColor="#004A99"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <!-- RatingBar — ID preserved -->
    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1"
        android:progressTint="#004A99"
        android:secondaryProgressTint="#E2E8F0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <!-- Comment Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COMMENT"
        android:textColor="#004A99"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <!-- Comment Field — ID preserved -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Write a review (optional)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine" />

    </com.google.android.material.textfield.TextInputLayout>

    <CheckBox
        android:id="@+id/cbAnonymous"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Post anonymously"
        android:layout_marginTop="12dp"
        android:textColor="#4B5563"
        android:textSize="13sp" />

</LinearLayout>