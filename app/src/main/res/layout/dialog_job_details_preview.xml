<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvDialogJobTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#004A99"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDialogCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schedule"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#94A3B8" />

        <TextView
            android:id="@+id/tvDialogSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#1E293B"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offered Amount"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#94A3B8" />

        <TextView
            android:id="@+id/tvDialogPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#16A34A"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#94A3B8" />

        <TextView
            android:id="@+id/tvDialogDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#1E293B"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Images"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#94A3B8"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/layoutDialogImages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Dynamic images -->
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvNoImages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No images provided"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            android:fontStyle="italic"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>