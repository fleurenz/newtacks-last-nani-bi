<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ToolbarTitleStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_card</item>
    </style>
    <style name="PrePromptChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="android:textSize">13sp</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:minHeight">40dp</item>
        <!-- prevent overly wide chips -->
        <item name="android:maxWidth">220dp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipBackgroundColor">#FFFFFF</item>
        <item name="chipStrokeColor">#2563EB</item>
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="android:textColor">#2563EB</item>
    </style>
</resources>